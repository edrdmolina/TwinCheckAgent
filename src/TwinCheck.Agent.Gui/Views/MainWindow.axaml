<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TwinCheck.Agent.Gui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="TwinCheck.Agent.Gui.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Width="880"
        Height="720"
        MinWidth="640"
        MinHeight="560"
        Title="TwinCheck Scan Agent">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Text="TwinCheck Scan Agent" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="Local scanner monitor and profile control" Foreground="#666666"/>
            </StackPanel>

            <Border Padding="16" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="6">
                <StackPanel Spacing="12">
                    <TextBlock Text="Agent" FontSize="16" FontWeight="SemiBold"/>
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="180,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Agent URL" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AgentUrl}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" Text="Config file" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="{Binding ConfigPath}" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,0,0" Text="Status" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="6">
                <StackPanel Spacing="14">
                    <DockPanel>
                        <TextBlock Text="Scanner profiles" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Content="Add profile" Click="AddProfile_Click"/>
                            <Button Content="Delete profile" Click="DeleteProfile_Click"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="160,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Agent name" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AgentName, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" Text="API key" FontWeight="SemiBold"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Orientation="Horizontal" Spacing="8">
                            <TextBox Width="420" PasswordChar="•" Text="{Binding ApiKey, Mode=TwoWay}"/>
                            <Button Content="Generate" Click="GenerateApiKey_Click"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,0,0" Text="Selected profile" FontWeight="SemiBold"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0"
                                  Items="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,12,0,0" Text="Profile ID" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Text="{Binding ProfileId, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,12,0,0" Text="Profile name" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Text="{Binding ProfileName, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,12,0,0" Text="Scanner mode" FontWeight="SemiBold"/>
                        <ComboBox Grid.Row="5" Grid.Column="1" Margin="0,12,0,0"
                                  Items="{Binding ScannerModeOptions}"
                                  SelectedItem="{Binding SelectedScannerModeOption, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,12,0,0" Text="Naming pattern" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Margin="0,12,0,0" Text="{Binding NamingPattern, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,12,0,0" Text="Weekly folders" FontWeight="SemiBold"/>
                        <CheckBox Grid.Row="7" Grid.Column="1" Margin="0,12,0,0" IsChecked="{Binding WeeklyDestination, Mode=TwoWay}" Content="Use week/order/roll destination structure"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,12,0,0" Text="Settle stable sec" FontWeight="SemiBold"/>
                        <NumericUpDown Grid.Row="8" Grid.Column="1" Margin="0,12,0,0" Minimum="0" Maximum="3600" Value="{Binding SettleStableSeconds, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,12,0,0" Text="Settle timeout sec" FontWeight="SemiBold"/>
                        <NumericUpDown Grid.Row="9" Grid.Column="1" Margin="0,12,0,0" Minimum="1" Maximum="7200" Value="{Binding SettleTimeoutSeconds, Mode=TwoWay}"/>

                        <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,12,0,0" Text="Settle poll sec" FontWeight="SemiBold"/>
                        <NumericUpDown Grid.Row="10" Grid.Column="1" Margin="0,12,0,0" Minimum="1" Maximum="300" Value="{Binding SettlePollSeconds, Mode=TwoWay}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="16" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="6">
                <StackPanel Spacing="14">
                    <TextBlock Text="Folders" FontSize="16" FontWeight="SemiBold"/>

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="160,*,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Source folder" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SourceDir, Mode=TwoWay}"/>
                        <Button Grid.Row="0" Grid.Column="2" Margin="8,0,0,0" Content="Browse..." Click="BrowseSource_Click"/>

                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding SourceHealth}" Foreground="#666666"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,14,0,0" Text="Destination folder" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,14,0,0" Text="{Binding DestinationDir, Mode=TwoWay}"/>
                        <Button Grid.Row="2" Grid.Column="2" Margin="8,14,0,0" Content="Browse..." Click="BrowseDestination_Click"/>

                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Text="{Binding DestinationHealth}" Foreground="#666666"/>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="Reload" Click="Reload_Click"/>
                <Button Content="Save profiles" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>

</Window>
